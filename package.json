{
  "name": "essentia-ecommerce",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma migrate deploy && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "migrate:deploy": "prisma migrate deploy",
    "db:migrate": "prisma migrate dev",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "news:fetch": "npx tsx scripts/fetchNews.ts",
    "import:products": "npx tsx scripts/importProducts.ts",
    "extract:disfragancias": "npx tsx scripts/extractDisfragancias.ts",
    "catalog:local": "python3 scripts/buildLocalAssetsCatalog.py",
    "catalog:match": "npx tsx scripts/matchLocalWithDisfragancias.ts",
    "catalog:candidate": "npx tsx scripts/buildEssentiaCandidateCatalog.ts",
    "prices:match": "npx tsx scripts/matchCatalogWithProviderPrices.ts",
    "prices:sheet": "npx tsx scripts/buildPricingSheet.ts",
    "images:sync": "npx tsx scripts/downloadAndUploadImages.ts",
    "extract:pdf": "python3 scripts/extract_pdf.py data/PRECIOS_2026.pdf",
    "import:pdf": "npx tsx scripts/importFromPDF.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.967.0",
    "@prisma/client": "^5.22.0",
    "next": "14.2.35",
    "prisma": "^5.22.0",
    "react": "^18",
    "react-dom": "^18",
    "sharp": "^0.34.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/sharp": "^0.31.1",
    "dotenv": "^17.3.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}

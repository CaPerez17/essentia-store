# Database (Neon / PostgreSQL)
# DATABASE_URL: pooled connection string (Neon pooled URL for serverless/connection pooling)
DATABASE_URL="postgresql://user:password@host:5432/essentia?sslmode=require"
# DATABASE_DIRECT_URL: direct connection for migrations (Neon non-pooled/direct URL)
DATABASE_DIRECT_URL="postgresql://user:password@host:5432/essentia?sslmode=require"

# Wompi (Colombia)
WOMPI_PUBLIC_KEY="pub_test_xxx"           # pub_prod_xxx for production
WOMPI_INTEGRITY_SECRET="prod_integrity_xxx" # From Dashboard > Secrets
WOMPI_EVENTS_SECRET="prod_events_xxx"      # For webhook verification
WOMPI_ENV="sandbox"                        # "sandbox" | "production"

# App
NEXT_PUBLIC_BASE_URL="https://tu-dominio.vercel.app"

# S3 (public bucket base URL for image keys)
# Example: https://your-bucket.s3.amazonaws.com or CloudFront URL
NEXT_PUBLIC_S3_PUBLIC_BASE_URL="https://your-bucket.s3.amazonaws.com"

# Admin (no auth; key in header x-admin-key)
ADMIN_API_KEY="your-secret-admin-key"

# Development only (mock webhooks)
# MOCK_WEBHOOK_SECRET="mock-secret-dev"
